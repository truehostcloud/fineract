<configuration>
    <springProperty name="jsonLoggingEnabled" source="fineract.logging.json.enabled" defaultValue="false"/>

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- ECS Encoder for APM -->
    <appender name="CONSOLE" target="System.out" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="co.elastic.logging.logback.EcsEncoder">
            <serviceName>fineract-dev</serviceName>
            <serviceVersion>1.0.0</serviceVersion>
            <serviceEnvironment>development</serviceEnvironment>
            <includeOrigin>true</includeOrigin>
        </encoder>
    </appender>

    <!-- Existing loggers -->
    <logger name="org.springframework.boot.web.embedded.tomcat.TomcatWebServer" level="info"/>
    <logger name="org.apache.fineract.ServerApplication" level="info"/>
    <logger name="org.apache.fineract" level="${FINERACT_LOGGING_LEVEL:-INFO}"/>
    <logger name="liquibase" level="warn"/>

    <!-- Your custom loggers -->
    <logger name="com.acme.fineract" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
    </logger>

    <if condition="${jsonLoggingEnabled} == true">
        <then>
            <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
                <!-- Use ECS JSON encoder instead of standard JSON -->
                <encoder class="co.elastic.logging.logback.EcsEncoder">
                    <serviceName>fineract-dev</serviceName>
                    <serviceVersion>1.0.0</serviceVersion>
                    <serviceEnvironment>development</serviceEnvironment>
                    <includeOrigin>true</includeOrigin>
                </encoder>
            </appender>

            <root level="info">
                <appender-ref ref="JSON"/>
            </root>
        </then>
        <else>
            <root level="info">
                <appender-ref ref="CONSOLE"/>
            </root>
        </else>
    </if>
</configuration>
